<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- ════════════════════════════════════════════════════════════════════
         PERMISSIONS
         ════════════════════════════════════════════════════════════════════ -->

    <!-- Draw overlay on top of all other apps (privacy shield view) -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!-- Keep overlay service alive in background -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />

    <!-- Android 14+ requires declaring foreground service type -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <!-- Post the persistent notification for the foreground service -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Prevent the system from killing our sensor-reading service -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <application
        android:label="Glance"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher"
        android:resizeableActivity="true">

        <!-- ════════════════════════════════════════════════════════════════
             MAIN ACTIVITY (Flutter Host)
             ════════════════════════════════════════════════════════════════ -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize"
            android:resizeableActivity="true">
            <!-- NOTE: Samsung showWhenLocked meta-data REMOVED (Task 3).
                 Only the overlay (GlanceOverlayService) should show on the
                 lock screen via FLAG_SHOW_WHEN_LOCKED on its WindowManager
                 params. The Flutter Activity must NOT appear over the lock
                 screen — that caused the app UI to display on top of it. -->
            <!-- TransparentTheme makes the Activity window translucent so
                 the TargetedAreaEditor can "see through" to the home screen
                 via a cut-out hole in the ScrimPainter overlay.
                 Other Flutter screens (Dashboard, Settings) explicitly set
                 backgroundColor: Colors.black to remain opaque. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/TransparentTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <!-- ════════════════════════════════════════════════════════════════
             GLANCE OVERLAY SERVICE
             Foreground Service that reads sensors and draws the privacy
             overlay via WindowManager.
             ════════════════════════════════════════════════════════════════ -->
        <service
            android:name=".GlanceOverlayService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="specialUse" />

        <!-- ════════════════════════════════════════════════════════════════
             QUICK SETTINGS TILE SERVICE
             Adds a toggle tile in Android's Quick Settings panel to
             start/stop the GlanceOverlayService without opening the app.
             ════════════════════════════════════════════════════════════════ -->
        <service
            android:name=".GlanceTileService"
            android:label="Glance"
            android:icon="@mipmap/ic_launcher"
            android:exported="true"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <!-- Flutter embedding meta-data -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
    </application>

    <!-- Required to query activities that can process text -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
    </queries>
</manifest>
